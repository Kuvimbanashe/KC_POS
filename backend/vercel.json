{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "sh build_files.sh",
  "functions": {
    "api/index.py": {
      "excludeFiles": "{__pycache__/**,**/*.pyc,db.sqlite3}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
