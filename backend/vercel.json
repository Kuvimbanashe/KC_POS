{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "python manage.py collectstatic --noinput",
  "functions": {
    "backend/wsgi.py": {
      "maxDuration": 30,
      "includeFiles": "staticfiles/**",
      "excludeFiles": "{README.md,build_files.sh,Procfile,.env.example,__pycache__/**,**/__pycache__/**}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/backend/wsgi.py"
    }
  ]
}
