{
  "expo": {
    "name": "Shop Manager",
    "slug": "shop-manager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "shop-manager",
    "newArchEnabled": true,
    "userInterfaceStyle": "automatic",
    
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "KC POS uses Bluetooth to discover and connect to supported receipt printers.",
        "NSBluetoothPeripheralUsageDescription": "KC POS uses Bluetooth to discover and connect to supported receipt printers.",
        "NSLocalNetworkUsageDescription": "KC POS uses your local network to discover and print to receipt printers in your shop.",
        "NSBonjourServices": [
          "_printer._tcp"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
     
      "predictiveBackGestureEnabled": false,
      "package": "com.camarader.shopmanager"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0d860e6c-a7a9-46ac-a5f4-aa77789c00cf"
      }
    }
  }
}
